<script>
// ═══════════════════════════════════════════════════════
//  PARALLAX ENGINE
//  5 layers, each with a distinct depth factor.
//  On mousemove: layers shift by (mouseOffset × depthFactor)
//  → background barely moves, foreground moves a lot
//  → creates clear, obvious 3D depth separation
// ═══════════════════════════════════════════════════════

const root  = document.getElementById('hero-root');
const l1    = document.getElementById('l1');       // stars
const l2    = document.getElementById('l2');       // circuit
const l3    = document.getElementById('l3');       // orbs
const l4    = document.getElementById('l4');       // code chips
const txtL  = document.getElementById('l5-text'); // text
const imgL  = document.getElementById('l5-img');  // image

// Depth factors: how many px per 1px of cursor offset
const D_STARS   = 0.015;
const D_CIRCUIT = 0.05;
const D_ORBS    = 0.10;
const D_CHIPS   = 0.20;
const D_TEXT    = 0.28;
const D_IMAGE   = 0.42;

// Current transform values (smoothed with lerp)
let cx = 0, cy = 0;       // raw mouse offset
let sx = 0, sy = 0;       // smoothed offset
let raf: number | null = null;

function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

function applyTransforms() {
  sx = lerp(sx, cx, 0.06); // 0.06 = smoothing (lower = slower/smoother)
  sy = lerp(sy, cy, 0.06);

  const move = (el: HTMLElement | null, d: number, invertX = false) => {
    if (!el) return;
    const dx = sx * d * (invertX ? -1 : 1);
    const dy = sy * d;
    el.style.transform = `translate(${dx}px, ${dy}px)`;
  };

  move(l1,   D_STARS);
  move(l2,   D_CIRCUIT);
  move(l3,   D_ORBS);
  // orbs counter move for parallax illusion
  if (l3) l3.style.transform = `translate(${sx * D_ORBS}px, ${sy * D_ORBS}px)`;
  move(l4,   D_CHIPS);
  move(txtL, D_TEXT);

  // Image gets rotation (3D tilt) + translation for extra depth
  if (imgL) {
    const rotY =  (sx / window.innerWidth)  * 18; // max 18deg
    const rotX = -(sy / window.innerHeight) * 12; // max 12deg
    const dx   = sx * D_IMAGE;
    const dy   = sy * D_IMAGE;
    imgL.style.transform = `translate(${dx}px, ${dy}px) perspective(600px) rotateY(${rotY}deg) rotateX(${rotX}deg)`;
  }

  // Keep animating until close to target
  if (Math.abs(sx - cx) > 0.05 || Math.abs(sy - cy) > 0.05) {
    raf = requestAnimationFrame(applyTransforms);
  } else {
    raf = null;
  }
}

if (root) {
  root.addEventListener('mousemove', (e) => {
    const r = root.getBoundingClientRect();
    cx = e.clientX - r.left  - r.width  / 2;
    cy = e.clientY - r.top   - r.height / 2;
    if (!raf) raf = requestAnimationFrame(applyTransforms);
  });

  root.addEventListener('mouseleave', () => {
    cx = 0; cy = 0;
    if (!raf) raf = requestAnimationFrame(applyTransforms);
  });
}

// ── STAR CANVAS ─────────────────────────────────────────────────
const canvas = document.getElementById('star-canvas') as HTMLCanvasElement;
if (canvas) {
  const ctx   = canvas.getContext('2d')!;
  const stars: { x: number; y: number; r: number; o: number; speed: number }[] = [];

  function resize() {
    canvas.width  = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  for (let i = 0; i < 160; i++) {
    stars.push({
      x: Math.random(),
      y: Math.random(),
      r: Math.random() * 1.2 + 0.3,
      o: Math.random() * 0.5 + 0.1,
      speed: Math.random() * 0.0003 + 0.0001,
    });
  }

  function drawStars() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Check if dark mode is active to change star color
    const isDark = document.documentElement.classList.contains('dark');
    const rgb = isDark ? '247,248,248' : '100,110,120';
    
    stars.forEach(s => {
      s.o += s.speed;
      if (s.o > 0.7) s.speed = -Math.abs(s.speed);
      if (s.o < 0.05) s.speed = Math.abs(s.speed);
      ctx.beginPath();
      ctx.arc(s.x * canvas.width, s.y * canvas.height, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${rgb},${s.o})`;
      ctx.fill();
    });
    requestAnimationFrame(drawStars);
  }
  drawStars();
}

// ── SCROLL PARALLAX ─────────────────────────────────────────────
// Background scrolls slower than foreground on scroll too
window.addEventListener('scroll', () => {
  const sy2 = window.scrollY;
  if (sy2 > window.innerHeight * 1.2) return;
  if (l1) l1.style.transform    = `translateY(${sy2 * 0.03}px)`;
  if (l2) l2.style.transform    = `translateY(${sy2 * 0.06}px)`;
  if (l3) l3.style.transform    = `translateY(${sy2 * 0.10}px)`;
  if (l4) l4.style.transform    = `translateY(${sy2 * 0.18}px)`;
  if (imgL) imgL.style.transform = `translateY(${sy2 * 0.28}px)`;
}, { passive: true });
</script>