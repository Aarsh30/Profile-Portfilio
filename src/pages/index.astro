  /* ── Card Base ──────────────────────────────────────── */
  .skill-card {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    padding: 1.5rem;
    background: var(--color-carbon-surface);
    border: 1px solid var(--color-ferrite-border);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
    /* left accent bar */
    border-left: 3px solid var(--cat-color);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .skill-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 40% at 110% -10%,
      color-mix(in srgb, var(--cat-color) 12%, transparent),
      transparent 70%
    );
    pointer-events: none;
    transition: opacity 0.4s ease;
    opacity: 0;
  }

  .skill-card:hover {
    border-color: color-mix(in srgb, var(--cat-color) 50%, var(--color-ferrite-border));
    box-shadow: 0 8px 40px -12px color-mix(in srgb, var(--cat-color) 25%, transparent);
    transform: translateY(-3px);
  }

  .skill-card:hover::before {
    opacity: 1;
  }

  /* ── Card Header ────────────────────────────────────── */
  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .skill-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    background: color-mix(in srgb, var(--cat-color) 15%, transparent);
    color: var(--cat-color);
    font-size: 0.95rem;
    font-weight: 700;
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  .skill-card:hover .skill-card-icon {
    background: color-mix(in srgb, var(--cat-color) 25%, transparent);
  }

  .skill-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mist-text);
    margin: 0;
  }

  /* ── Pill Row ───────────────────────────────────────── */
