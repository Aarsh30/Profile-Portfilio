---
import Btn from '@elements/Btn.astro';
import Heading from '@elements/Heading.astro';
import ProjectCard from '@components/ProjectCard.astro';
import Skill from '@components/Skill.astro';

import Layout from '@layouts/Layout.astro';

import getImageURL from '@utils/getImageURL';
import projectsData from '@data/projectsData';
import skillsData from '@data/skillsData';
---

<Layout>

<!-- ═══════════════════════════════════════════════════════════════
     PARALLAX HERO — Full viewport height, 5 depth layers.
     Each layer has an id. JavaScript moves them at different
     speeds on mousemove → you literally see things at different
     Z depths floating past each other as you move the cursor.
     ═══════════════════════════════════════════════════════════════ -->

<div
  id="hero-root"
  class="relative w-full overflow-hidden bg-canvas transition-colors duration-300"
  style="height:100vh;min-height:640px;margin-top:-5rem;"
>

  <!-- ── LAYER 1 ──  Star / particle dots  (depth factor 0.02 — barely moves) ── -->
  <div id="l1" class="absolute inset-0 pointer-events-none" style="will-change:transform;">
    <canvas id="star-canvas" style="width:100%;height:100%;display:block;"></canvas>
  </div>

  <!-- ── LAYER 2 ──  Circuit board SVG lines  (depth 0.06) ── -->
  <div id="l2" class="absolute inset-0 pointer-events-none opacity-25" style="will-change:transform;">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <line x1="0" y1="20%" x2="30%" y2="20%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="30%" y1="20%" x2="30%" y2="50%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="30%" y1="50%" x2="60%" y2="50%" stroke="var(--color-ferrite-border)" stroke-width="1"/>
      <line x1="70%" y1="0" x2="70%" y2="35%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="70%" y1="35%" x2="100%" y2="35%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="0" y1="75%" x2="20%" y2="75%" stroke="var(--color-ferrite-border)" stroke-width="1"/>
      <line x1="20%" y1="75%" x2="20%" y2="100%" stroke="var(--color-ferrite-border)" stroke-width="1"/>
      <line x1="60%" y1="50%" x2="60%" y2="80%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="60%" y1="80%" x2="100%" y2="80%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <!-- glowing nodes -->
      <circle cx="30%"  cy="20%"  r="4" fill="#188aec" opacity="0.8"/>
      <circle cx="30%"  cy="50%"  r="4" fill="#8b5cf6" opacity="0.7"/>
      <circle cx="60%"  cy="50%"  r="4" fill="#188aec" opacity="0.7"/>
      <circle cx="70%"  cy="35%"  r="4" fill="#f59e0b" opacity="0.7"/>
      <circle cx="60%"  cy="80%"  r="4" fill="#8b5cf6" opacity="0.7"/>
      <circle cx="20%"  cy="75%"  r="4" fill="#22c55e" opacity="0.7"/>
    </svg>
  </div>

  <!-- ── LAYER 3 ──  Glowing atmosphere orbs  (depth 0.12) ── -->
  <div id="l3" class="absolute inset-0 pointer-events-none" style="will-change:transform;">
    <div style="position:absolute;top:-15%;left:-10%;width:520px;height:520px;border-radius:50%;background:rgba(24,138,236,0.15);filter:blur(130px);"></div>
    <div style="position:absolute;bottom:-20%;right:-12%;width:460px;height:460px;border-radius:50%;background:rgba(139,92,246,0.12);filter:blur(120px);"></div>
  </div>

  <!-- ── LAYER 4 ──  Floating code snippets  (depth 0.22) ── -->
  <div id="l4" class="absolute inset-0 pointer-events-none select-none" style="will-change:transform;">

    <div class="absolute top-[10%] left-[4%] font-mono text-xs leading-relaxed text-fog border border-ferrite bg-carbon px-3.5 py-2.5 rounded-lg shadow-sm">
      <span class="text-[#c084fc]">const</span> <span class="text-[#7dd3fc]">engineer</span> = () =&gt; {"{"}
      <br/>&nbsp;&nbsp;<span class="text-[#86efac]">buildAwesome</span>(<span class="text-[#fde68a]">"product"</span>)
      <br/>{"}"}
    </div>

    <div class="absolute top-[7%] right-[6%] font-mono text-xs text-fog border border-ferrite bg-carbon px-3.5 py-2 rounded-lg shadow-sm">
      <span class="text-[#c084fc]">git</span> push origin <span class="text-[#86efac]">main</span> 🚀
    </div>

    <div class="absolute top-[44%] left-[2%] font-mono text-xs text-[#34d399] border border-[#34d399]/30 bg-carbon px-3 py-1.5 rounded-lg shadow-sm">
      &lt;<span class="text-[#7dd3fc]">Engineer</span> /&gt;
    </div>

    <div class="absolute bottom-[16%] right-[4%] font-mono text-xs leading-relaxed text-fog border border-ferrite bg-carbon px-3.5 py-2.5 rounded-lg shadow-sm">
      <span class="text-[#c084fc]">while</span>(<span class="text-[#7dd3fc]">alive</span>) {"{"}
      <br/>&nbsp;&nbsp;<span class="text-[#fde68a]">skills</span>++
      <br/>{"}"}
    </div>

    <div class="absolute bottom-[30%] left-[4%] font-mono text-[10px] text-blue border border-blue/30 bg-carbon px-2.5 py-1 rounded-full">SwiftUI</div>
    <div class="absolute top-[27%] right-[3%] font-mono text-[10px] text-[#8b5cf6] border border-[#8b5cf6]/30 bg-carbon px-2.5 py-1 rounded-full">Python</div>
    <div class="absolute bottom-[20%] left-[22%] font-mono text-[10px] text-[#22c55e] border border-[#22c55e]/30 bg-carbon px-2.5 py-1 rounded-full">Cloud &amp; DevOps</div>
    <div class="absolute top-[62%] right-[5%] font-mono text-[10px] text-[#f59e0b] border border-[#f59e0b]/30 bg-carbon px-2.5 py-1 rounded-full">System Design</div>
    <div class="absolute top-[80%] left-[12%] font-mono text-[10px] text-rose-400 border border-rose-400/30 bg-carbon px-2.5 py-1 rounded-full">iOS Dev</div>
    <div class="absolute bottom-[40%] right-[10%] font-mono text-[10px] text-teal-400 border border-teal-400/30 bg-carbon px-2.5 py-1 rounded-full">Backend Architecture</div>
  </div>

  <!-- ── LAYER 5 ──  Foreground content (text depth 0.30, image depth 0.42) ── -->
  <div class="absolute inset-0 flex items-center z-10">
    <div class="w-full max-w-[1080px] mx-auto px-6 md:px-20 lg:px-40 flex flex-col md:flex-row items-center justify-between gap-12 md:gap-8">

      <!-- TEXT — moves at depth 0.30 -->
      <div id="l5-text" class="flex-1 flex flex-col gap-5" style="will-change:transform;">



        <h1 class="text-[clamp(2.2rem,5vw,4rem)] font-bold text-snow tracking-tight leading-[1.15] m-0">
          Hello! 👋🏻<br/>
          I'm&nbsp;<span id="grad-name" style="background:linear-gradient(90deg,#188aec 0%,#8b5cf6 50%,#188aec 100%);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:nameShimmer 4s linear infinite;">Aarsh</span>
        </h1>

        <h2 class="text-[clamp(1rem,2.2vw,1.4rem)] font-medium text-mist m-0">
          Engineer, a trade of all stack + Content Creator
        </h2>

        <p class="text-[15px] text-fog leading-[1.7] max-w-[380px] m-0">
          Building real-world software solutions — one elegant commit at a time.
        </p>

        <!-- stat strip -->
        <div class="flex items-center gap-5 font-mono text-[11px] text-steel mt-1">
          <div class="flex flex-col gap-0.5">
            <span class="text-[20px] font-bold text-snow font-inherit">100+</span>
            <span>LeetCode</span>
          </div>
          <div class="w-px h-8 bg-ash"></div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[20px] font-bold text-snow font-inherit">10k+</span>
            <span>YT Subs</span>
          </div>
          <div class="w-px h-8 bg-ash"></div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[20px] font-bold text-snow font-inherit">3+</span>
            <span>Certs</span>
          </div>
        </div>

        <div class="flex items-center gap-4 flex-wrap mt-1">
          <Btn btnText="Connect Me" btnRedirectLink="https://www.linkedin.com/in/aarshpatel30/" />
          <a href="/#projects" class="text-[14px] text-fog hover:text-snow underline underline-offset-4 transition-colors">
            View Projects →
          </a>
        </div>

      </div>

      <!-- IMAGE — moves at depth 0.42 (fastest = closest to viewer) -->
      <div id="l5-img" class="flex-1 flex justify-center items-center relative" style="will-change:transform;">
        <!-- halo glow behind image -->
        <div class="absolute w-[450px] h-[450px] rounded-full bg-[#188aec]/15 blur-[90px] pointer-events-none"></div>
        <img
          src="/assets/images/3d model.png"
          alt="Aarsh Patel — Software Engineer"
          class="relative w-[110%] max-w-[650px] object-contain select-none transition-transform duration-150 ease-out drop-shadow-[0_20px_70px_rgba(24,138,236,0.3)] animate-float transform lg:scale-110"
          draggable="false"
        />
      </div>

    </div>
  </div>

  <!-- Bottom page fade -->
  <div class="absolute bottom-0 left-0 right-0 h-[120px] bg-gradient-to-b from-transparent to-canvas pointer-events-none"></div>

</div>
<!-- end hero -->

