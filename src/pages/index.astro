---
import Btn from '@elements/Btn.astro';
import Heading from '@elements/Heading.astro';
import Skill from '@components/Skill.astro';

import Layout from '@layouts/Layout.astro';

import projectsData from '@data/projectsData';
import skillsData from '@data/skillsData';
---


<Layout>

<!-- ═══════════════════════════════════════════════════════════════
     PARALLAX HERO — Full viewport height, 5 depth layers.
     Each layer has an id. JavaScript moves them at different
     speeds on mousemove → you literally see things at different
     Z depths floating past each other as you move the cursor.
     ═══════════════════════════════════════════════════════════════ -->

<div
  id="hero-root"
  class="relative w-full overflow-hidden bg-canvas transition-colors duration-300"
  style="height:100vh;min-height:640px;margin-top:-5rem;"
>

  <!-- ── LAYER 1 ──  Star / particle dots  (depth factor 0.02 — barely moves) ── -->
  <div id="l1" class="absolute inset-0 pointer-events-none" style="will-change:transform;">
    <canvas id="star-canvas" style="width:100%;height:100%;display:block;"></canvas>
  </div>

  <!-- ── LAYER 2 ──  Circuit board SVG lines  (depth 0.06) ── -->
  <div id="l2" class="absolute inset-0 pointer-events-none opacity-25" style="will-change:transform;">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <line x1="0" y1="20%" x2="30%" y2="20%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="30%" y1="20%" x2="30%" y2="50%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="30%" y1="50%" x2="60%" y2="50%" stroke="var(--color-ferrite-border)" stroke-width="1"/>
      <line x1="70%" y1="0" x2="70%" y2="35%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="70%" y1="35%" x2="100%" y2="35%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="0" y1="75%" x2="20%" y2="75%" stroke="var(--color-ferrite-border)" stroke-width="1"/>
      <line x1="20%" y1="75%" x2="20%" y2="100%" stroke="var(--color-ferrite-border)" stroke-width="1"/>
      <line x1="60%" y1="50%" x2="60%" y2="80%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <line x1="60%" y1="80%" x2="100%" y2="80%" stroke="var(--color-ash-border)" stroke-width="1"/>
      <!-- glowing nodes -->
      <circle cx="30%"  cy="20%"  r="4" fill="#188aec" opacity="0.8"/>
      <circle cx="30%"  cy="50%"  r="4" fill="#8b5cf6" opacity="0.7"/>
      <circle cx="60%"  cy="50%"  r="4" fill="#188aec" opacity="0.7"/>
      <circle cx="70%"  cy="35%"  r="4" fill="#f59e0b" opacity="0.7"/>
      <circle cx="60%"  cy="80%"  r="4" fill="#8b5cf6" opacity="0.7"/>
      <circle cx="20%"  cy="75%"  r="4" fill="#22c55e" opacity="0.7"/>
    </svg>
  </div>

  <!-- ── LAYER 3 ──  Glowing atmosphere orbs  (depth 0.12) ── -->
  <div id="l3" class="absolute inset-0 pointer-events-none" style="will-change:transform;">
    <div style="position:absolute;top:-15%;left:-10%;width:520px;height:520px;border-radius:50%;background:rgba(24,138,236,0.15);filter:blur(130px);"></div>
    <div style="position:absolute;bottom:-20%;right:-12%;width:460px;height:460px;border-radius:50%;background:rgba(139,92,246,0.12);filter:blur(120px);"></div>
  </div>

  <!-- ── LAYER 4 ──  Floating code snippets  (depth 0.22) ── -->
  <div id="l4" class="absolute inset-0 pointer-events-none select-none" style="will-change:transform;">

    <div class="absolute top-[10%] left-[4%] font-mono text-xs leading-relaxed text-fog border border-ferrite bg-carbon px-3.5 py-2.5 rounded-lg shadow-sm">
      <span class="text-[#c084fc]">const</span> <span class="text-[#7dd3fc]">engineer</span> = () =&gt; {"{"}
      <br/>&nbsp;&nbsp;<span class="text-[#86efac]">buildAwesome</span>(<span class="text-[#fde68a]">"product"</span>)
      <br/>{"}"}
    </div>

    <div class="absolute top-[7%] right-[6%] font-mono text-xs text-fog border border-ferrite bg-carbon px-3.5 py-2 rounded-lg shadow-sm">
      <span class="text-[#c084fc]">git</span> push origin <span class="text-[#86efac]">main</span>
    </div>

    <div class="absolute top-[44%] left-[2%] font-mono text-xs text-[#34d399] border border-[#34d399]/30 bg-carbon px-3 py-1.5 rounded-lg shadow-sm">
      &lt;<span class="text-[#7dd3fc]">Engineer</span> /&gt;
    </div>

    <div class="absolute bottom-[16%] right-[4%] font-mono text-xs leading-relaxed text-fog border border-ferrite bg-carbon px-3.5 py-2.5 rounded-lg shadow-sm">
      <span class="text-[#c084fc]">while</span>(<span class="text-[#7dd3fc]">alive</span>) {"{"}
      <br/>&nbsp;&nbsp;<span class="text-[#fde68a]">skills</span>++
      <br/>{"}"}
    </div>

    <div class="absolute bottom-[30%] left-[4%] font-mono text-[10px] text-blue border border-blue/30 bg-carbon px-2.5 py-1 rounded-full">SwiftUI</div>
    <div class="absolute top-[27%] right-[3%] font-mono text-[10px] text-[#8b5cf6] border border-[#8b5cf6]/30 bg-carbon px-2.5 py-1 rounded-full">Python</div>
    <div class="absolute bottom-[20%] left-[22%] font-mono text-[10px] text-[#22c55e] border border-[#22c55e]/30 bg-carbon px-2.5 py-1 rounded-full">Cloud &amp; DevOps</div>
    <div class="absolute top-[62%] right-[5%] font-mono text-[10px] text-[#f59e0b] border border-[#f59e0b]/30 bg-carbon px-2.5 py-1 rounded-full">System Design</div>
    <div class="absolute top-[80%] left-[12%] font-mono text-[10px] text-rose-400 border border-rose-400/30 bg-carbon px-2.5 py-1 rounded-full">iOS Dev</div>
    <div class="absolute bottom-[40%] right-[10%] font-mono text-[10px] text-teal-400 border border-teal-400/30 bg-carbon px-2.5 py-1 rounded-full">Backend Architecture</div>
  </div>

  <!-- ── LAYER 5 ──  Foreground content (text depth 0.30, image depth 0.42) ── -->
  <div class="absolute inset-0 flex items-center z-10">
    <div class="w-full max-w-[1080px] mx-auto px-6 md:px-20 lg:px-40 flex flex-col md:flex-row items-center justify-between gap-12 md:gap-8">

      <!-- TEXT — moves at depth 0.30 -->
      <div id="l5-text" class="flex-1 flex flex-col gap-5" style="will-change:transform;">



        <h1 class="text-[clamp(2.2rem,5vw,4rem)] font-bold text-snow tracking-tight leading-[1.15] m-0">
          Hello!<br/>
          I'm&nbsp;<span id="grad-name" style="background:linear-gradient(90deg,#188aec 0%,#8b5cf6 50%,#188aec 100%);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:nameShimmer 4s linear infinite;">Aarsh</span>
        </h1>

        <h2 class="text-[clamp(1rem,2.2vw,1.4rem)] font-medium text-mist m-0">
          Engineer, a trade of all stack + Content Creator
        </h2>

        <p class="text-[15px] text-fog leading-[1.7] max-w-[380px] m-0">
          Building real-world software solutions — one elegant commit at a time.
        </p>

        <!-- stat strip -->
        <div class="flex items-center gap-5 font-mono text-[11px] text-steel mt-1">
          <div class="flex flex-col gap-0.5">
            <span class="text-[20px] font-bold text-snow font-inherit">100+</span>
            <span>LeetCode</span>
          </div>
          <div class="w-px h-8 bg-ash"></div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[20px] font-bold text-snow font-inherit">10k+</span>
            <span>YT Subs</span>
          </div>
          <div class="w-px h-8 bg-ash"></div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[20px] font-bold text-snow font-inherit">3+</span>
            <span>Certs</span>
          </div>
        </div>

        <div class="flex items-center gap-4 flex-wrap mt-1">
          <Btn btnText="Connect Me" btnRedirectLink="https://www.linkedin.com/in/aarshpatel30/" />
          <a href="/#projects" class="text-[14px] text-fog hover:text-snow underline underline-offset-4 transition-colors">
            View Projects →
          </a>
        </div>

      </div>

      <!-- IMAGE — moves at depth 0.42 (fastest = closest to viewer) -->
      <div id="l5-img" class="flex-1 flex justify-center items-center relative" style="will-change:transform;">
        <!-- halo glow behind image -->
        <div class="absolute w-[450px] h-[450px] rounded-full bg-[#188aec]/15 blur-[90px] pointer-events-none"></div>
        <img
          src="/assets/images/3d model.png"
          alt="Aarsh Patel — Software Engineer"
          class="relative w-[110%] max-w-[650px] object-contain select-none transition-transform duration-150 ease-out drop-shadow-[0_20px_70px_rgba(24,138,236,0.3)] animate-float transform lg:scale-110"
          draggable="false"
        />
      </div>

    </div>
  </div>

  <!-- Bottom page fade -->
  <div class="absolute bottom-0 left-0 right-0 h-[120px] bg-gradient-to-b from-transparent to-canvas pointer-events-none"></div>

</div>
<!-- end hero -->

<div class="max-w-[1080px] mx-auto w-full px-6 md:px-20 lg:px-40 flex flex-col gap-28 py-20">
  <!-- About Section -->
  <section id="about" class="scroll-mt-24 flex flex-col gap-10">
    <div class="flex flex-col gap-7 text-md md:text-lg">
      <div class="flex flex-col gap-1">
        <Heading>About Me</Heading>
      </div>
      
      <div class="text-mist leading-relaxed flex flex-col gap-5">
        <p>Hi, I'm <strong class="text-snow font-bold">Aarsh Patel</strong>.</p>
        
        <p>I'm a Software Engineer based in India, passionate about building products that solve real-world problems and create meaningful impact. I enjoy transforming ideas into scalable applications, writing clean and maintainable code, and continuously exploring new technologies.</p>
        
        <p>Currently, I work as a Software Engineer, where I focus on designing and developing high-quality software solutions while constantly improving my technical and problem-solving skills.</p>
        
        <p>Beyond engineering, my core mission is to impact education in every single household and support the well-being of needy people. I channel this passion through content creation, mentorship, and actively building educational platforms to help students navigate their careers and achieve their full potential.</p>
        
        <p class="text-snow mt-2 font-medium">Over the years, I've:</p>
        
        <ul class="flex flex-col gap-4 text-mist">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-[#188aec] flex-shrink-0 mt-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <span>Graduated from VIT 2024 with the Highest CGPA Award in my branch.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-[#188aec] flex-shrink-0 mt-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <span>Delivered talks at colleges and developer communities on software engineering and iOS development.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-[#188aec] flex-shrink-0 mt-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <span>Built a community of 25,000+ learners across YouTube, LinkedIn, and other platforms.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-[#188aec] flex-shrink-0 mt-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <span>Mentored 250+ students in placements, projects, and career growth.</span>
          </li>
        </ul>
        
        <p class="mt-2">When I'm away from coding, you'll usually find me reading books, creating content, exploring new ideas, or working on projects that help people learn and grow.</p>
        
        <p>I believe great software is built by continuously learning, experimenting, and staying curious—and that's the mindset I bring to everything I do.</p>
      </div>
    </div>
    <div class="mt-2">
      <Btn btnText="Say Hello" btnRedirectLink="mailto:contactaarsh@yahoo.com" />
    </div>
  </section>

  <!-- Purpose & Impact Section -->
  <section id="purpose" class="scroll-mt-24 flex flex-col gap-10 py-10">
    <div class="flex flex-col gap-2">
      <Heading>Purpose & Impact</Heading>
      <p class="text-fog text-[15px]">The core mission that drives my engineering and content creation journey.</p>
    </div>

    <div class="purpose-container">
      <div class="purpose-spotlight">
        <div class="purpose-spotlight-content">
          <div class="purpose-badge">MISSION & VISION</div>
          <h3 class="purpose-quote">"To impact education in every single household and support the well-being of people."</h3>
          <p class="purpose-subtext">
            I believe that quality technical education and personal development should be accessible to everyone. My journey as a software engineer and content creator is driven by building platforms that bring learning to every home while supporting wellness and community growth.
          </p>
        </div>
        <div class="purpose-visual">
          <div class="glowing-orb-container">
            <div class="glowing-orb-pulse"></div>
            <svg viewBox="0 0 100 100" class="purpose-svg" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
                  <path d="M 10 0 L 0 0 0 10" fill="none" stroke="rgba(24, 138, 236, 0.08)" stroke-width="0.5"/>
                </pattern>
                <linearGradient id="blue-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#188aec" />
                  <stop offset="100%" stop-color="#8b5cf6" />
                </linearGradient>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid)" />
              <circle cx="50" cy="50" r="38" stroke="rgba(24, 138, 236, 0.25)" stroke-width="1.5" stroke-dasharray="4 3" />
              <circle cx="50" cy="50" r="32" stroke="#188aec" stroke-width="1" opacity="0.3" />
              
              <!-- Education Motif (Graduation cap structure) -->
              <path d="M50 32 L75 42 L50 52 L25 42 Z" fill="url(#blue-grad)" opacity="0.85" />
              <path d="M35 46.5 V58 C35 62 50 66 50 66 C50 66 65 62 65 58 V46.5" stroke="#188aec" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M68 45.5 V59" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round" />
              <circle cx="68" cy="60" r="2.5" fill="#8b5cf6" />
              
              <!-- Well-being Motif (Heart in the center/underneath) -->
              <path d="M50 61 C50 61 46 57.5 43 54.5 C40 51.5 39 49 41 46.5 C43.5 43.5 47.5 45.5 50 48.5 C52.5 45.5 56.5 43.5 59 46.5 C61 49 60 51.5 57 54.5 C54 57.5 50 61 50 61 Z" fill="#188aec" opacity="0.9" transform="translate(0, 4) scale(0.9) translate(5, -5)" />
            </svg>
          </div>
        </div>
      </div>

      <div class="purpose-pillars">
        <!-- Pillar 1: Education -->
        <div class="pillar-card">
          <div class="pillar-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
              <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
            </svg>
          </div>
          <h4 class="pillar-title">Household Education</h4>
          <p class="pillar-desc">
            Empowering every single household with high-quality tech learning. Through scalable online platforms like swe180.com, swiftyn.com, and community initiatives, I make engineering knowledge accessible to all.
          </p>
        </div>

        <!-- Pillar 2: Well-being -->
        <div class="pillar-card">
          <div class="pillar-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h4 class="pillar-title">Social Well-being</h4>
          <p class="pillar-desc">
            Extending support to improve the quality of life and well-being of needy people. Leveraging my resources, network, and development skills, I actively support and build tools for community wellness and outreach programs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="scroll-mt-24 flex flex-col gap-10 py-10">
    <div class="flex flex-col gap-2">
      <Heading>Skills</Heading>
      <p class="text-fog text-[15px]">My technical toolkit — languages, frameworks, and platforms I work with.</p>
    </div>

    <!-- Bento Grid -->
    <div class="skills-bento">
      {
        skillsData.map((category) => (
          <div
            class="skill-card"
            style={`--cat-color: ${category.categoryColor};`}
          >
            <!-- accent bar + header -->
            <div class="skill-card-header">
              <span class="skill-card-icon">{category.categoryIcon}</span>
              <h3 class="skill-card-title">{category.skillType}</h3>
            </div>

            <!-- pill group -->
            <div class="skill-pills">
              {category.skills.map((s) => (
                <Skill skillName={s.skillName} color={s.color} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="scroll-mt-24 flex flex-col gap-12 py-10">
    <div class="flex flex-col gap-3">
      <Heading>Projects</Heading>
      <p class="text-fog">Currently scaling ongoing platforms and archiving my past engineering work.</p>
    </div>

    <!-- Active / Ongoing Scaling Projects -->
    <div class="flex flex-col gap-6">
      <h3 class="text-xs font-bold uppercase tracking-wider text-[#188aec]">⚡ Current Focus (Scaling)</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- SWE180 -->
        <div class="active-project-card">
          <div class="active-project-header">
            <div class="flex items-center gap-3">
              <img src="https://i.ibb.co/YT27GQvx/swe180white.png" alt="SWE180 Logo" class="w-12 h-12 rounded-xl object-contain bg-[#1e1e1e] p-1.5 border border-ferrite" />
              <h4 class="active-project-title">SWE180</h4>
            </div>
          </div>
          <p class="active-project-desc">
            An education and career acceleration platform designed for software engineers. Providing placement prep, structured guides, and real-world mentorship.
          </p>
          <div class="active-project-footer">
            <a href="https://swe180.com" target="_blank" rel="noopener noreferrer" class="active-project-link">
              Visit swe180.com
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" width="14" height="14">
                <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Swiftyn -->
        <div class="active-project-card">
          <div class="active-project-header">
            <div class="flex items-center gap-3">
              <img src="https://i.ibb.co/h1yJCX02/finalswiftynlogo.png" alt="Swiftyn Logo" class="w-12 h-12 rounded-xl object-contain bg-[#1e1e1e] p-1.5 border border-ferrite" />
              <h4 class="active-project-title">Swiftyn</h4>
            </div>
          </div>
          <p class="active-project-desc">
            A specialized native iOS development ecosystem. Helping mobile engineers scale their Swift & SwiftUI knowledge through architectural templates and deep-dive guides.
          </p>
          <div class="active-project-footer">
            <a href="https://swiftyn.com" target="_blank" rel="noopener noreferrer" class="active-project-link">
              Visit swiftyn.com
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" width="14" height="14">
                <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Past Selected Projects (Smaller layout) -->
    <div class="flex flex-col gap-6 mt-4">
      <h3 class="text-xs font-bold uppercase tracking-wider text-steel">📁 Past Selected Projects</h3>
      <div class="past-projects-grid">
        {
          projectsData.map((project) => (
            <div class="past-project-card">
              <div class="flex flex-col gap-2">
                <h4 class="past-project-title">{project.projectName}</h4>
                <p class="past-project-desc text-sm text-fog leading-relaxed">{project.projectDescription}</p>
              </div>
              <div class="flex gap-4">
                {project.projectRepoURL && (
                  <a
                    href={project.projectRepoURL}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-[#188aec] hover:text-snow hover:underline font-semibold flex items-center gap-1"
                  >
                    GitHub
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Achievements Section -->
  <section id="achievements" class="scroll-mt-24 flex flex-col md:flex-row items-center justify-between gap-10 py-10">
    <div class="flex-1 flex flex-col gap-5">
      <Heading>Achievements</Heading>
      <p class="text-fog">Some of my achievements over the past few years:</p>
      <div>
         <ul class="list-disc pl-5 flex flex-col gap-3 text-mist text-lg md:text-xl">
           <li>AIR 256 in CodeJam Farewell in Round A.</li>
           <li>Solved 100+ Problems on LeetCode.</li>
           <li>Microsoft Azure Fundamentals Certified.</li>
           <li>Google Cloud Platform Foundational.</li>
           <li>Top 10 in SDG GDSC Hackathon.</li>
           <li>Top 10 in DataBid Hackathon.</li>
         </ul>
      </div>
    </div>
    <div class="flex-1 flex justify-center items-center">
      <img src="/assets/images/1.png" alt="Achievements 3D model" class="max-w-[80%] max-h-[80%] filter drop-shadow-[0_20px_50px_rgba(24,138,236,0.2)]" />
    </div>
  </section>

  <!-- Social Connections Section -->
  <section id="socials" class="scroll-mt-24 flex flex-col gap-10 py-10">
    <div class="flex flex-col gap-2">
      <Heading>Connect & Community</Heading>
      <p class="text-fog text-[15px]">Find me online or join my developer communities on other platforms.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <!-- YouTube -->
