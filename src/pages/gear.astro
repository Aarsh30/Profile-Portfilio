---
import Layout from '@layouts/Layout.astro';
import gearData from '@data/gearData';
import booksData from '@data/booksData';
---

<Layout>
  <div class="gear-page">

    <!-- Hero -->
    <div class="gear-hero">
      <span class="gear-tag">Tech Gear & Books</span>
      <h1 class="gear-title">My Setup & Recommendations</h1>
      <p class="gear-subtitle">
        Everything I use daily, upcoming upgrades, and my favorite self-help books.
        Affiliate links — all affiliate income goes entirely towards helping needy people.
      </p>
    </div>

    <!-- Tabs Navigation -->
    <div class="gear-tabs-container">
      <div class="gear-tabs" role="tablist" aria-label="Gear categories">
        <button class="gear-tab-btn active" role="tab" aria-selected="true" aria-controls="pane-setup" id="tab-setup">
          <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
          My Setup
        </button>
        <button class="gear-tab-btn" role="tab" aria-selected="false" aria-controls="pane-decor" id="tab-decor">
          <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
            <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
            <line x1="6" y1="2" x2="6" y2="4"></line>
            <line x1="10" y1="2" x2="10" y2="4"></line>
            <line x1="14" y1="2" x2="14" y2="4"></line>
          </svg>
          Desk & Decor
        </button>
        <button class="gear-tab-btn" role="tab" aria-selected="false" aria-controls="pane-wishlist" id="tab-wishlist">
          <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          Tech Wishlist
        </button>
        <button class="gear-tab-btn" role="tab" aria-selected="false" aria-controls="pane-bookshelf" id="tab-bookshelf">
          <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
          </svg>
          Bookshelf
        </button>
      </div>
    </div>

    <!-- Tab Panes -->
    <div class="gear-panes">
      
      <!-- Pane: My Setup (Tech Products) -->
      <div class="gear-pane active" id="pane-setup" role="tabpanel" aria-labelledby="tab-setup">
        <div class="gear-lists">
          {gearData.filter(cat => cat.category === 'Tech Products').map((cat) => (
            <section class="gear-cat">
              <!-- Category label -->
              <div class="gear-cat-label">
                <span>{cat.category}</span>
              </div>

              <!-- List rows -->
              <ul class="gear-list">
                {cat.items.map((item, i) => (
                  <li class="gear-row">
                    <div class="gear-row-left">
                      <span class="gear-row-num">{String(i + 1).padStart(2, '0')}</span>
                      <div class="gear-row-info">
                        <span class="gear-row-name">{item.name}</span>
                        {item.badge && <span class="gear-row-badge">{item.badge}</span>}
                      </div>
                    </div>
                    <a
                      href={item.affiliateUrl}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                      class="gear-row-link"
                      aria-label={`View ${item.name} on Amazon`}
                    >
                      View on Amazon
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" width="12" height="12">
                        <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>

      <!-- Pane: Desk & Decor (Desktop Accessories & Decor) -->
      <div class="gear-pane" id="pane-decor" role="tabpanel" aria-labelledby="tab-decor">
        <div class="gear-lists">
          {gearData.filter(cat => cat.category === 'Desktop Accessories & Decor').map((cat) => (
            <section class="gear-cat">
              <!-- Category label -->
              <div class="gear-cat-label">
                <span>{cat.category}</span>
              </div>

              <!-- List rows -->
              <ul class="gear-list">
                {cat.items.map((item, i) => (
                  <li class="gear-row">
                    <div class="gear-row-left">
                      <span class="gear-row-num">{String(i + 1).padStart(2, '0')}</span>
                      <div class="gear-row-info">
                        <span class="gear-row-name">{item.name}</span>
                        {item.badge && <span class="gear-row-badge">{item.badge}</span>}
                      </div>
                    </div>
                    <a
                      href={item.affiliateUrl}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                      class="gear-row-link"
                      aria-label={`View ${item.name} on Amazon`}
                    >
                      View on Amazon
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" width="12" height="12">
                        <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>

      <!-- Pane: Tech Wishlist (Upcoming Tech Upgrades) -->
      <div class="gear-pane" id="pane-wishlist" role="tabpanel" aria-labelledby="tab-wishlist">
        <div class="gear-lists">
          {gearData.filter(cat => cat.category === 'Upcoming Tech Upgrades').map((cat) => (
            <section class="gear-cat">
              <!-- Category label -->
              <div class="gear-cat-label">
                <span>{cat.category}</span>
              </div>

              <!-- List rows -->
              <ul class="gear-list">
                {cat.items.map((item, i) => (
                  <li class="gear-row">
                    <div class="gear-row-left">
                      <span class="gear-row-num">{String(i + 1).padStart(2, '0')}</span>
                      <div class="gear-row-info">
                        <span class="gear-row-name">{item.name}</span>
                        {item.badge && <span class="gear-row-badge">{item.badge}</span>}
                      </div>
                    </div>
                    <a
                      href={item.affiliateUrl}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                      class="gear-row-link"
                      aria-label={`View ${item.name} on Amazon`}
                    >
                      View on Amazon
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" width="12" height="12">
                        <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>

      <!-- Pane: Bookshelf (booksData grouped by category) -->
      <div class="gear-pane" id="pane-bookshelf" role="tabpanel" aria-labelledby="tab-bookshelf">
        <div class="gear-lists">
          {booksData.map((cat) => (
            <section class="gear-cat">
              <!-- Category label -->
              <div class="gear-cat-label">
                <span>{cat.category}</span>
              </div>

              <!-- List rows -->
              <ul class="gear-list">
                {cat.books.map((book, i) => (
                  <li class="gear-row">
                    <div class="gear-row-left">
                      <span class="gear-row-num">{String(i + 1).padStart(2, '0')}</span>
                      <div class="gear-row-info">
                        <span class="gear-row-name">{book.title}</span>
                      </div>
                    </div>
                    <a
                      href={book.affiliateUrl}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                      class="gear-row-link"
                      aria-label={`Buy ${book.title} on Amazon`}
                    >
                      Buy on Amazon
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" width="12" height="12">
                        <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom note -->
    <div class="gear-note">
      <p class="gear-note-main">
        If you purchase anything through these links, <strong>all affiliate income goes entirely towards the well-being of needy people.</strong>
        Your purchase — at zero extra cost to you — directly helps someone in need.
      </p>
      <p class="gear-note-sub">
        Thank you for your support. It means the world.
        &nbsp;·&nbsp;
        <a href="mailto:contactaarsh@yahoo.com">Say hi for collabs →</a>
      </p>
    </div>

  </div>
</Layout>

<script is:inline>
  // Setup client-side tab toggling
  const setupTabs = () => {
    const tabs = document.querySelectorAll('.gear-tab-btn');
    const panes = document.querySelectorAll('.gear-pane');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Deactivate all tabs
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });

        // Hide all panes
        panes.forEach(pane => {
          pane.classList.remove('active');
        });

        // Activate selected tab
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        // Show corresponding pane
        const targetId = tab.getAttribute('aria-controls');
        const targetPane = document.getElementById(targetId || '');
        if (targetPane) {
          targetPane.classList.add('active');
        }
      });
    });
  };

  // Run on page load and support hydration reset if needed
  setupTabs();
  
  // Also run setup when content is updated dynamically (e.g. view transitions)
  document.addEventListener('astro:page-load', setupTabs);
</script>

<style>
  /* ─── Outer shell ───────────────────────────────────────────────────── */
  .gear-page {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    box-sizing: border-box;
    padding: 4rem 1rem 5.5rem;   /* 4rem top gap below sticky header */
  }
  @media (min-width: 640px)  { .gear-page { padding: 4rem 2rem   5rem; } }
  @media (min-width: 768px)  { .gear-page { padding: 5rem 3rem   3rem; } }
  @media (min-width: 1024px) { .gear-page { padding: 5rem 4rem   3rem; } }

  /* ─── Hero ─────────────────────────────────────────────────────────── */
  .gear-hero {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 640px) { .gear-hero { gap: 1rem; margin-bottom: 2.5rem; } }

  .gear-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #188aec;
    background: rgba(24,138,236,0.1);
    border: 1px solid rgba(24,138,236,0.25);
    padding: 0.3rem 0.85rem;
    border-radius: 9999px;
    width: fit-content;
  }

  .gear-title {
    font-size: clamp(1.8rem, 6vw, 3.5rem);
    font-weight: 800;
    color: var(--color-snow);
    line-height: 1.1;
    margin: 0;
    letter-spacing: -0.02em;
    overflow-wrap: break-word;
  }

  .gear-subtitle {
    font-size: 0.95rem;
    color: var(--color-fog-text);
    line-height: 1.7;
    margin: 0;
    overflow-wrap: break-word;
  }
  @media (min-width: 640px) { .gear-subtitle { font-size: 1rem; max-width: 560px; } }

  /* ─── Tabs ──────────────────────────────────────────────────────────── */
  /* Mobile: 2×2 grid — never overflows */
  .gear-tabs-container {
    margin-bottom: 2rem;
    width: 100%;
    box-sizing: border-box;
  }

  .gear-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem;
    padding: 0.35rem;
    background: var(--color-carbon-surface);
    border: 1px solid var(--color-ferrite-border);
    border-radius: 16px;
    width: 100%;
    box-sizing: border-box;
  }

  /* ≥640px: pill strip (scrollable if needed) */
  @media (min-width: 640px) {
    .gear-tabs-container {
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .gear-tabs-container::-webkit-scrollbar { display: none; }
    .gear-tabs {
      display: flex;
      flex-wrap: nowrap;
      border-radius: 9999px;
      min-width: max-content;
      width: 100%;
    }
  }

  .gear-tab-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 44px;
    padding: 0.5rem 0.4rem;
    border: none;
    border-radius: 11px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-pewter-text);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    width: 100%;
    box-sizing: border-box;
  }
  @media (min-width: 640px) {
    .gear-tab-btn {
      border-radius: 9999px;
      padding: 0.55rem 1.3rem;
      font-size: 0.95rem;
      min-height: unset;
      width: auto;
    }
  }
  .gear-tab-btn:hover { color: var(--color-snow); background: rgba(24,138,236,0.06); }
  .gear-tab-btn.active { color: #fff; background: #188aec; box-shadow: 0 4px 14px rgba(24,138,236,0.3); }

  .tab-icon { width: 14px; height: 14px; flex-shrink: 0; }
  @media (min-width: 640px) { .tab-icon { width: 16px; height: 16px; } }

  /* ─── Panes ─────────────────────────────────────────────────────────── */
  .gear-pane { display: none; }
  .gear-pane.active { display: block; }

  /* ─── Lists ─────────────────────────────────────────────────────────── */
  .gear-lists { display: flex; flex-direction: column; gap: 2rem; }
  @media (min-width: 640px) { .gear-lists { gap: 2.5rem; } }

  .gear-cat { display: flex; flex-direction: column; gap: 0.4rem; }

  .gear-cat-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #188aec;
    margin-bottom: 0.25rem;
  }

  /* ─── List card ─────────────────────────────────────────────────────── */
  .gear-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-ferrite-border);
    border-radius: 14px;
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
  }

  /* ─── Row (mobile: stacked, desktop: side-by-side) ──────────────────── */
  .gear-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--color-ferrite-border);
    background: var(--color-carbon-surface);
    transition: background 0.15s ease;
    box-sizing: border-box;
    width: 100%;
  }
  @media (min-width: 640px) {
    .gear-row {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1.25rem;
    }
  }
  .gear-row:last-child { border-bottom: none; }
  .gear-row:hover { background: rgba(24,138,236,0.04); }

  .gear-row-left {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    min-width: 0;
    flex: 1;
  }
  @media (min-width: 640px) { .gear-row-left { align-items: center; } }

  .gear-row-num {
    font-size: 0.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--color-steel-text);
    flex-shrink: 0;
    padding-top: 0.15rem;
    min-width: 1.5rem;
  }
  @media (min-width: 640px) { .gear-row-num { padding-top: 0; } }

  .gear-row-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    flex: 1;
  }
  @media (min-width: 640px) {
    .gear-row-info { flex-direction: row; align-items: center; gap: 0.5rem; }
  }

  .gear-row-name {
    font-size: 0.975rem;
    font-weight: 600;
    color: var(--color-snow);
    line-height: 1.4;
    overflow-wrap: break-word;
  }

  .gear-row-badge {
    display: inline-block;
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #188aec;
    background: rgba(24,138,236,0.1);
    border: 1px solid rgba(24,138,236,0.25);
    padding: 0.15rem 0.45rem;
    border-radius: 9999px;
    width: fit-content;
    flex-shrink: 0;
  }

  /* Row link — full width on mobile, auto on desktop */
  .gear-row-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #188aec;
    text-decoration: none;
    padding: 0.6rem 1rem;
    border: 1px solid rgba(24,138,236,0.28);
    border-radius: 9px;
    background: rgba(24,138,236,0.07);
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
    width: 100%;
    box-sizing: border-box;
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }
  @media (min-width: 640px) {
    .gear-row-link {
      width: auto;
      border-radius: 9999px;
      padding: 0.35rem 0.9rem;
      font-size: 0.83rem;
      min-height: unset;
    }
    .gear-row-link:hover {
      background: rgba(24,138,236,0.14);
      border-color: rgba(24,138,236,0.5);
      transform: translateX(2px);
    }
  }

  /* ─── Bottom note ───────────────────────────────────────────────────── */
  .gear-note {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-align: center;
    padding: 1.5rem 1.25rem;
    border-radius: 14px;
    border: 1px solid rgba(24,138,236,0.2);
    background: rgba(24,138,236,0.04);
    margin-top: 2.5rem;
    width: 100%;
    box-sizing: border-box;
  }
  @media (min-width: 640px) { .gear-note { padding: 2rem 2.5rem; margin-top: 3.5rem; } }

  .gear-note-main {
    font-size: 0.9rem;
    color: var(--color-mist-text);
    line-height: 1.7;
    margin: 0;
  }
  @media (min-width: 640px) { .gear-note-main { font-size: 1rem; max-width: 520px; } }
  .gear-note-main strong { color: #188aec; font-weight: 700; }

  .gear-note-sub { font-size: 0.8rem; color: var(--color-steel-text); margin: 0; }
  .gear-note-sub a { color: #188aec; text-decoration: none; font-weight: 600; border-bottom: 1px solid rgba(24,138,236,0.3); }
  .gear-note-sub a:hover { color: #4fa8f5; border-color: rgba(79,168,245,0.5); }
</style>

