---
import { motion } from 'framer-motion';

import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Bottombar from '@components/Bottombar.astro';
import '@/base.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = "Aarsh Patel — Software Engineer & Content Creator",
  description = "Portfolio of Aarsh Patel, Software Engineer based in India specializing in Go, SwiftUI, Core Data, and AI Engineering. Founder of SWE180 & Swiftyn.",
  image = "/assets/images/3d model.png",
  type = "website"
} = Astro.props;

const animations = {
  initial: { opacity: 0, y: 20 },
  animate: { opacity: 1, y: 0 },
  exit: { opacity: 0, y: -20 },
};
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/assets/icons/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/assets/icons/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary SEO Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Aarsh Patel" />
    <meta name="keywords" content="Aarsh Patel, Software Engineer, iOS Developer, Go Developer, SwiftUI, Core Data, AI Engineering, Model Context Protocol, SWE180, Swiftyn, Vellore Institute of Technology, VIT" />
    
    <!-- OpenGraph / Facebook / LinkedIn Meta Tags -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content="https://aarshpatel.in/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Aarsh Patel Portfolio" />
    
    <!-- Twitter Meta Tags -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://aarshpatel.in/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
    <meta property="twitter:site" content="@aarsh_30" />
    <meta property="twitter:creator" content="@aarsh_30" />
    
    <style>
      /* Glowing Orbs Animation */
      @keyframes float {
        0%, 100% { transform: translateY(0px) scale(1); }
        50% { transform: translateY(-20px) scale(1.03); }
      }
      .animate-float { animation: float 12s ease-in-out infinite; }
      .animate-float-delayed { animation: float 15s ease-in-out infinite; animation-delay: 3s; }

      /* Floating code chip animation — each chip gets a slightly different timing */
      @keyframes floatChip {
        0%   { transform: translateY(0px)   rotate(0deg); }
        30%  { transform: translateY(-10px) rotate(0.4deg); }
        70%  { transform: translateY(-6px)  rotate(-0.4deg); }
        100% { transform: translateY(0px)   rotate(0deg); }
      }

      /* Gradient shimmer sweep on the hero name */
      @keyframes shimmer {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }
      .animate-shimmer {
        animation: shimmer 4s ease-in-out infinite;
        background-size: 200% auto;
      }

      /* Smooth scroll behaviour for the entire page */
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-canvas text-snow font-inter transition-colors duration-300 min-h-screen overflow-x-hidden selection:bg-smoke selection:text-snow">
    <!-- Foreground Content -->
    <Header />
    
    <motion.main
      className="flex flex-col gap-32 w-full relative z-10"
      variants={animations}
      initial="initial"
      animate="animate"
      exit="exit"
      transition={{ duration: 0.5, ease: 'easeOut' }}
      client:load
    >
      <slot />
    </motion.main>
    <Footer />
    <Bottombar />

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </body>
</html>
