---
import BottombarIcon from '@elements/BottombarIcon.astro';
import ThemeToggle from '@components/ThemeToggle';

import navItems from './navItems';
---

<!-- Floating Bottom Navigation Dock for Mobile/Tablet -->
<div
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex md:hidden justify-center items-center gap-2.5 bg-carbon/95 backdrop-blur-md border border-ash rounded-[9999px] py-1.5 px-3.5 shadow-lg"
>
  {navItems.map((navItem) => <BottombarIcon navItem={navItem} />)}
  <div class="border-l border-ash h-8 mx-1"></div>
  <ThemeToggle client:load />
</div>
