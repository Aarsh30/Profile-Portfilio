---
import ThemeToggle from '@components/ThemeToggle';
import navItems from './navItems';
---

<header class="sticky w-full top-0 left-0 z-50 backdrop-blur-md border-b border-ash bg-canvas/80">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 py-4 flex items-center justify-between w-full">
    <a href="/" class="flex items-center gap-2">
      <h1 class="text-snow font-inter font-[590] text-xl tracking-tight">
       Aarsh Patel
      </h1>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {navItems.map((item) => (
        <a 
          href={item.route} 
          class="text-sm font-inter font-[510] text-fog hover:text-snow transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:flex items-center gap-4">
      <div class="w-px h-5 bg-ash"></div>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
