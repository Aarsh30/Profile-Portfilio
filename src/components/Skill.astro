---
export interface Props {
  skillName: string;
  color?: string;
}

const { skillName, color = '#188aec' } = Astro.props;
---

<span
  class="skill-pill"
  style={`--pill-color: ${color};`}
>
  {skillName}
</span>

<style>
  .skill-pill {
    display: inline-block;
    padding: 0.45rem 1rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.02em;
    color: var(--pill-color);
    background: color-mix(in srgb, var(--pill-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--pill-color) 30%, transparent);
    cursor: default;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
  }

  .skill-pill:hover {
    background: color-mix(in srgb, var(--pill-color) 20%, transparent);
    border-color: color-mix(in srgb, var(--pill-color) 60%, transparent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px -4px color-mix(in srgb, var(--pill-color) 40%, transparent);
  }
</style>
