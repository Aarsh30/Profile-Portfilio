<style>
  .footer-root {
    width: 100%;
    border-top: 1px solid var(--color-ferrite-border);
    background: var(--color-carbon-surface);
    margin-top: 5rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .footer-inner {
      padding: 3rem 3rem;
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .footer-inner {
      padding: 3rem 4rem;
    }
  }

  /* Brand col */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-name {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-snow);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.2s;
  }

  .footer-name:hover { color: #188aec; }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--color-fog-text);
    line-height: 1.65;
    margin: 0;
    max-width: 280px;
  }

  /* Socials */
  .footer-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.4rem;
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-ferrite-border);
    color: var(--color-fog-text);
    text-decoration: none;
    background: transparent;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .footer-social-link:hover {
    color: #188aec;
    border-color: rgba(24, 138, 236, 0.4);
    background: rgba(24, 138, 236, 0.08);
  }

  /* Link cols */
  .footer-links-col {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .footer-col-heading {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-steel-text);
    margin: 0;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.82rem;
    color: var(--color-fog-text);
    text-decoration: none;
    transition: color 0.18s;
  }

  .footer-link:hover { color: var(--color-snow); }

  /* Contact */
  .footer-email {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: #188aec;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-email:hover { color: #4fa8f5; }

  .footer-contact-note {
    font-size: 0.75rem;
    color: var(--color-steel-text);
    line-height: 1.5;
    margin: 0;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-ferrite-border);
    padding: 1.25rem 1.5rem 6.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .footer-bottom { padding: 1.25rem 3rem; }
  }

  @media (min-width: 1024px) {
    .footer-bottom { padding: 1.25rem 4rem; }
  }

  .footer-copy,
  .footer-made {
    font-size: 0.75rem;
    color: var(--color-steel-text);
    margin: 0;
  }

  .footer-made {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .footer-heart {
    display: inline-block;
    animation: heartbeat 1.4s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    14%       { transform: scale(1.25); }
    28%       { transform: scale(1); }
    42%       { transform: scale(1.18); }
    56%       { transform: scale(1); }
  }
</style>
