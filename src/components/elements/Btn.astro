---
export interface Props {
  btnText: string;
  btnRedirectLink?: string;
}
const { btnText, btnRedirectLink } = Astro.props;
---

<a
  href={btnRedirectLink ?? '/'}
  target="blank"
  class="inline-block text-snow bg-transparent border border-snow py-2 px-6 rounded-[9999px] text-center text-sm md:text-base font-medium transition-all hover:bg-smoke focus:outline-none focus:ring-2 focus:ring-ash"
>
  {btnText}
</a>
